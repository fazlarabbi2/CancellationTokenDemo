<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CancellationToken Demo</title>

    <!-- Bootstrap 5 latest -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-dark navbar-expand-lg border-bottom border-secondary px-3 py-2" id="mainNav">
        <div class="container-fluid">
            <span class="navbar-brand fw-bold fs-5">
                <i class="bi bi-cpu me-2 text-info"></i>CancellationToken Demo
            </span>
            <span class="text-secondary small d-none d-md-inline">
                <i class="bi bi-terminal me-1"></i>Watch the server console while testing each scenario
            </span>
            <span class="badge bg-success ms-auto">
                <i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>.NET 8 MVC
            </span>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- jQuery 4 -->
    <script src="https://code.jquery.com/jquery-4.0.0.min.js"></script>
    <!-- Bootstrap 5 bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
</body>
</html>
